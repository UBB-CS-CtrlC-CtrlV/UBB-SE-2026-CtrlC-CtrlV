<Page
    x:Class="MovieApp.Ui.Views.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        Padding="32"
        VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24">
            <StackPanel Spacing="6">
                <TextBlock
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="Notifications" />
                <TextBlock
                    Style="{StaticResource SectionCaptionTextStyle}"
                    Text="Favorite-event notifications live here and stay separate from price-watcher alerts by requirement." />
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Text="Favorite-event notification feed" />
                        <TextBlock
                            Style="{StaticResource SectionCaptionTextStyle}"
                            Text="Price-drop and seats-reopened notifications should be rendered here and persisted for later viewing." />
                        <ListView Height="420">
                            <ListViewItem Content="Price drop | Sci-fi Premiere | 2026-03-23 09:10" />
                            <ListViewItem Content="Seats reopened | Classic Marathon | 2026-03-23 09:18" />
                            <ListViewItem Content="Price drop | Indie Showcase | 2026-03-23 10:05" />
                        </ListView>
                    </StackPanel>
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Spacing="16">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                Text="Selected notification detail" />
                            <TextBlock
                                Style="{StaticResource SectionCaptionTextStyle}"
                                Text="Use this panel for the message body, event linkage, read state, and deep-link navigation back to details." />
                            <TextBox Header="Notification type" Text="Bind type here" />
                            <TextBox Header="Event title" Text="Bind event here" />
                            <TextBox
                                AcceptsReturn="True"
                                Header="Message"
                                Height="120"
                                Text="Bind the short persisted message here." />
                            <Button Content="Open related event" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StrongSurfaceCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                Text="Deduplication and state notes" />
                            <TextBlock
                                Style="{StaticResource SectionCaptionTextStyle}"
                                Text="Wire the one-notification-per-relevant-state rule here so repeated refreshes do not create duplicates." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
