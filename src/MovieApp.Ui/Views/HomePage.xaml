<Page
    x:Class="MovieApp.Ui.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MovieApp.Core.Models"
    mc:Ignorable="d">

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Style="{ThemeResource HeaderTextBlockStyle}"
            Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}" />

        <!-- Loading indicator -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            <TextBlock
                HorizontalAlignment="Center"
                Text="Loading events..." />
        </StackPanel>

        <!-- Empty state -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8"
            Visibility="{x:Bind ViewModel.HasNoEvents, Mode=OneWay}">
            <FontIcon
                HorizontalAlignment="Center"
                FontSize="48"
                Glyph="&#xE7BA;" />
            <TextBlock
                HorizontalAlignment="Center"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="No events available" />
            <TextBlock
                HorizontalAlignment="Center"
                Opacity="0.6"
                Text="Check back later for upcoming events."
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <!-- Event list -->
        <ListView
            Grid.Row="1"
            Margin="0,16,0,0"
            ItemsSource="{x:Bind ViewModel.VisibleEvents, Mode=OneWay}"
            SelectionMode="None"
            Visibility="{x:Bind ViewModel.ShowEventList, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Event">
                    <Grid Padding="12" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0" Grid.Column="0"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            Text="{x:Bind Title}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Row="1" Grid.Column="0"
                            Opacity="0.6"
                            Text="{x:Bind LocationReference}"
                            TextTrimming="CharacterEllipsis" />

                        <TextBlock
                            Grid.Row="0" Grid.Column="1"
                            HorizontalAlignment="Right"
                            Text="{x:Bind TicketPrice}" />
                        <TextBlock
                            Grid.Row="1" Grid.Column="1"
                            HorizontalAlignment="Right"
                            Opacity="0.6"
                            Text="{x:Bind AvailableSpots}" />

                        <TextBlock
                            Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                            VerticalAlignment="Center"
                            Opacity="0.6"
                            Text="{x:Bind EventDateTime}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>