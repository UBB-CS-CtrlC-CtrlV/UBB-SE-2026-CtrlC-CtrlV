<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MovieApp.Ui.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Margin="16,16,16,0"
            Style="{StaticResource SurfaceCardStyle}">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock
                        Style="{ThemeResource TitleTextBlockStyle}"
                        Text="{x:Bind ViewModel.AppTitle, Mode=OneWay}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.Greeting, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource SectionCaptionTextStyle}"
                        Text="{x:Bind ViewModel.Description, Mode=OneWay}" />
                </StackPanel>

                <Grid
                    Grid.Column="1"
                    ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Style="{StaticResource StrongSurfaceCardStyle}">
                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource MiniLabelTextStyle}"
                                Text="User context" />
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="Dummy authenticated user" />
                            <TextBlock
                                Style="{StaticResource SectionCaptionTextStyle}"
                                Text="All features are surfaced in-app with no login flow." />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource StrongSurfaceCardStyle}">
                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource MiniLabelTextStyle}"
                                Text="Layout status" />
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="Implementation-ready shell" />
                            <TextBlock
                                Style="{StaticResource SectionCaptionTextStyle}"
                                Text="Each screen exposes stable mount points for feature teams." />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <controls:NavigationView
            x:Name="AppNavigationView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="False"
            Margin="0,12,0,0"
            PaneDisplayMode="Top"
            SelectionChanged="AppNavigationView_SelectionChanged">

            <controls:NavigationView.MenuItems>
                <controls:NavigationViewItem
                    x:Name="HomeNavigationItem"
                    Content="Home"
                    Icon="Home"
                    Tag="Home" />
                <controls:NavigationViewItem
                    Content="Details"
                    Icon="Preview"
                    Tag="DetailsCheckout" />
                <controls:NavigationViewItem
                    Content="My Events"
                    Icon="Calendar"
                    Tag="MyEvents" />
                <controls:NavigationViewItem
                    Content="Manage"
                    Icon="Edit"
                    Tag="EventManagement" />
                <controls:NavigationViewItem
                    Content="Favorites"
                    Icon="Favorite"
                    Tag="Favorites" />
                <controls:NavigationViewItem
                    Content="Alerts"
                    Icon="Message"
                    Tag="Notifications" />
                <controls:NavigationViewItem
                    Content="Rewards"
                    Icon="Like"
                    Tag="Rewards" />
                <controls:NavigationViewItem
                    Content="Referral"
                    Icon="Share"
                    Tag="ReferralArea" />
                <controls:NavigationViewItem
                    Content="Slots"
                    Icon="Shop"
                    Tag="SlotMachine" />
                <controls:NavigationViewItem
                    Content="Trivia Wheel"
                    Icon="Help"
                    Tag="TriviaWheel" />
                <controls:NavigationViewItem
                    Content="Marathons"
                    Icon="Play"
                    Tag="Marathons" />
            </controls:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </controls:NavigationView>
    </Grid>
</Window>
