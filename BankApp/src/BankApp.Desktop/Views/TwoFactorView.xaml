<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankApp.Desktop.Views.TwoFactorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- ─── Left panel: branding ─────────────────────────────────── -->
        <Grid Grid.Column="0" Background="#1A1A2E" Padding="40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="70" Height="70" CornerRadius="15" Background="#16213E"
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <FontIcon Glyph="&#xE8D7;" FontSize="32" Foreground="#4ECDC4"/>
                </Border>
                <TextBlock Text="Security" FontSize="32" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Protecting your account." FontSize="14"
                           Foreground="#888" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ─── Right panel: OTP form ─────────────────────────────────── -->
        <Grid Grid.Column="1" Padding="60">
            <StackPanel VerticalAlignment="Center" MaxWidth="360" HorizontalAlignment="Center">

                <TextBlock Text="Two-Factor Authentication"
                           FontSize="24" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Enter the 6-digit code sent to your device to continue."
                           Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,30"/>

                <!-- OTP input — IsEnabled and value are driven by ViewModel -->
                <TextBox x:Name="OtpBox"
                         PlaceholderText="000000"
                         MaxLength="6"
                         Header="Authentication Code"
                         Margin="0,0,0,20"
                         CornerRadius="6"
                         TextAlignment="Center"
                         FontSize="24"
                         IsEnabled="{x:Bind ViewModel.IsInputEnabled, Mode=OneWay}"
                         TextChanged="OtpBox_TextChanged"/>

                <!-- Verify button — disabled while loading or locked -->
                <Button x:Name="VerifyButton"
                        Content="VERIFY CODE"
                        Click="VerifyButton_Click"
                        HorizontalAlignment="Stretch"
                        Height="42"
                        Background="#4ECDC4"
                        Foreground="White"
                        FontWeight="SemiBold"
                        CornerRadius="6"
                        IsEnabled="{x:Bind ViewModel.IsInputEnabled, Mode=OneWay}"/>

                <!-- Loading indicator — visible while ViewModel.IsLoading is true -->
                <ProgressRing x:Name="LoadingRing"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Visibility="{x:Bind BoolToVisibility(ViewModel.IsLoading), Mode=OneWay}"
                              Margin="0,16,0,0"
                              Width="30"
                              Height="30"
                              HorizontalAlignment="Center"/>

                <!-- Error bar — driven by ViewModel.HasError / ErrorMessage -->
                <InfoBar x:Name="ErrorInfoBar"
                         IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                         Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                         Severity="Error"
                         Margin="0,16,0,0"
                         IsClosable="True"/>

                <!-- Resend + countdown row -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <HyperlinkButton x:Name="ResendButton"
                                     Content="Resend Code"
                                     Click="ResendButton_Click"
                                     FontSize="13"
                                     IsEnabled="{x:Bind ViewModel.CanResend, Mode=OneWay}"/>
                    <TextBlock x:Name="CountdownText"
                               Text="{x:Bind ViewModel.CountdownDisplayText, Mode=OneWay}"
                               Visibility="{x:Bind BoolToVisibility(ViewModel.IsCountdownVisible), Mode=OneWay}"
                               Foreground="#888"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>

                <HyperlinkButton x:Name="BackToLoginButton"
                                 Content="Back to Login"
                                 Click="BackToLoginButton_Click"
                                 HorizontalAlignment="Center"
                                 Margin="0,20,0,0"
                                 FontSize="13"
                                 Foreground="#888"/>

            </StackPanel>
        </Grid>
    </Grid>
</Page>