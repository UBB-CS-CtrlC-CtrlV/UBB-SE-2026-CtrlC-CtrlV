{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "SET-VIA-ENV: ConnectionStrings__DefaultConnection"
  },
  "Jwt": {
    "Secret": "SET-VIA-ENV: Jwt__Secret"
  },
  "Otp": {
    "ServerSecret": "SET-VIA-ENV: Otp__ServerSecret"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "SmtpUser": "SET-VIA-ENV: Email__SmtpUser",
    "SmtpPass": "SET-VIA-ENV: Email__SmtpPass",
    "FromAddress": "SET-VIA-ENV: Email__FromAddress"
  }
}
