# Copy this file to .env and fill in the values before running docker compose.
# .env is gitignored — never commit real credentials.

# ── Database ────────────────────────────────────────────────────────────────────
# SQL Server SA password. Must be 8+ characters and include uppercase,
# lowercase, a digit, and a special character (SQL Server requirement).
DB_SA_PASSWORD=YourStrong!Passw0rd

# ── JWT ─────────────────────────────────────────────────────────────────────────
# Signing key for JWT tokens. Generate a random value with:
#   python scripts/server/setup-dev-secrets.py
# Minimum 32 characters; 48+ recommended.
JWT_SECRET=CHANGE_ME

# ── Email (SMTP) ────────────────────────────────────────────────────────────────
# Gmail example. Use an App Password, not your account password.
# Generate one at: Google Account > Security > 2-Step Verification > App passwords
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASS=your-app-password
EMAIL_FROM_ADDRESS=your-email@gmail.com
